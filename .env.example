# ComfyUI 配置
COMFYUI_HOST=http://127.0.0.1:8188
COMFYUI_ROOT=/opt/comfyui/ComfyUI
COMFYUI_PORT=8188

# LoRA 模型目录
LORA_MODEL_DIR=/opt/comfyui/models/loras

# Pretags 数据文件路径（推荐配置，也可通过 CLI --pretags-path 参数单独指定）
# 指向文件：
#   PRETAGS_DATA_PATH=./pretags/pretags-anima.json
#   PRETAGS_DATA_PATH=./pretags/pretags-ill-noob.json
# 或指向目录（自动选择目录中第一个 JSON 文件）：
PRETAGS_DATA_PATH=./pretags/

# Civitai API（可选，用于模型下载）
# CIVITAI_API_KEY=your_api_key_here

# 代理配置（可选，仅 Civitai/Danbooru 需要）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
