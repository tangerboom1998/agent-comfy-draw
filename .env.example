# ComfyUI Draw 项目环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ============================================
# ComfyUI 配置（必需）
# ============================================

# ComfyUI 服务地址（必需）
# 本地部署示例: http://127.0.0.1:8188
# 远程部署示例: http://your-server-ip:8188
COMFYUI_HOST=http://127.0.0.1:8188

# ComfyUI 工作流文件路径（可选，默认使用项目内置工作流）
# COMFYUI_WORKFLOW_PATH=./comfyui-api/workflows/sdxl_txt2img.json

# ComfyUI 输出目录（可选，默认: ./output）
COMFYUI_OUTPUT_DIR=./output

# ============================================
# ComfyUI 本地启动配置（comfyui-startup 模块）
# ============================================

# ComfyUI 安装路径（必需，用于本地启动）
# 示例: /home/user/ComfyUI 或 C:/ComfyUI
# COMFYUI_PATH=/path/to/ComfyUI

# Python 环境配置（二选一）
# 方式 A：直接指定 Python 路径（推荐，更简单）
# COMFYUI_PYTHON_PATH=/path/to/anaconda3/envs/comfy311/bin/python
#
# 方式 B：通过 Conda 配置（传统方式）
# CONDA_PATH=/path/to/anaconda3        # 或 miniconda3
# COMFYUI_CONDA_ENV=comfy311           # ComfyUI 的 conda 环境名

# GPU 配置（可选）
# CUDA_VISIBLE_DEVICES=0         # 单卡模式：0 或 1
# CUDA_VISIBLE_DEVICES=1,0       # 多卡模式：GPU 1 优先

# 代理配置（可选，仅下载模型时需要）
# HTTP_PROXY=http://proxy.example.com:2090
# HTTPS_PROXY=http://proxy.example.com:2090

# ============================================
# Civitai API 配置（可选）
# ============================================

# Civitai API Key（可选，用于下载模型和访问私有资源）
# 获取地址: https://civitai.com/user/account
# CIVITAI_API_KEY=your_api_key_here

# Civitai API Host（可选， https://civitai.com,https://civitai.red）
# CIVITAI_HOST=https://civitai.com

# ============================================
# Tanger-Presets-Show 配置
# ============================================

# Tanger-Presets-Show Web 服务端口（默认: 8765）
WEB_SHOW_PORT=8765

# Pretags 数据路径（支持文件或目录）
# - 指定单个文件: PRETAGS_DATA_PATH=/path/to/pretags.json
# - 指定目录: PRETAGS_DATA_PATH=/path/to/pretags_directory
#   (目录模式下会扫描所有 .json 文件，Web 界面可切换)
# - 默认: 自动搜索项目根目录的 pretags.json
# PRETAGS_DATA_PATH=/path/to/pretags.json
# PRETAGS_DATA_PATH=/path/to/pretags_configs

# ============================================
# LoRA 模型路径配置
# ============================================

# LoRA 模型存储根目录
# 目录结构: $LORA_MODEL_DIR/{model_type}/{category}/
#   model_type 由文件名关键字自动检测:
#     "noob"/"illustrious" → illustrious&noob/
#     "turbo"/"z_image"    → z_image_turbo/
#     "anima" / 默认       → anima/
#   category: 人物/ 画风/ 服装/ 其他/ z-image/ z-flux/ wan/ ...
# LORA_MODEL_DIR=/path/to/models/loras


# ============================================
# 高级配置（可选）
# ============================================

# 日志级别（DEBUG, INFO, WARNING, ERROR）
# LOG_LEVEL=INFO

# 并发生图数量限制（默认: 4）
# MAX_CONCURRENT_GENERATIONS=4

# WebSocket 超时时间（秒，默认: 300）
# WEBSOCKET_TIMEOUT=300

# 图片质量（1-100，默认: 95）
# IMAGE_QUALITY=95

# ============================================
# 开发环境配置（仅开发时使用）
# ============================================

# 开发模式（启用调试日志和热重载）
# DEV_MODE=false

# 跨域配置（开发时可能需要）
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080
